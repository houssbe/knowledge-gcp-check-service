{
  "compilerOptions": {
    "target": "es2020",
    "module": "esnext",
    "lib": [
      "DOM",
      "DOM.Iterable",
      "ES2020"
    ],
    "skipLibCheck": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "strict": true,
    "noImplicitAny": true,
    "baseUrl": ".",
    "paths": {
      "*": [
        "src/*",
        "../src/*"
      ]
    }
  },
  "include": [
    "src/**/*"
  ]
}